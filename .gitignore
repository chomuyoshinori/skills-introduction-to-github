# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Blender #
###########
*.blend1
*.blend2
# 巨大な中間ファイルは原則コミットしない（必要なら Git LFS を使う）。
assets/**/highpoly/*.blend
# 書き出し済み中間バイナリ（最終 export/ はコミット対象）
*.fbx
*.obj

# Python #
##########
__pycache__/
*.pyc
.venv/
